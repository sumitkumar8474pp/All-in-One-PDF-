<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.PDFMaker" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#4F46E5</item>
        <item name="colorPrimaryVariant">#4338CA</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#4F46E5</item>
        <item name="colorSecondaryVariant">#4338CA</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.App.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#4F46E5</item>
        <item name="windowSplashScreenAnimatedIcon">@android:drawable/ic_menu_edit</item>
        <item name="postSplashScreenTheme">@style/Theme.PDFMaker</item>
    </style>
</resources>
